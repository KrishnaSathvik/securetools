# SecureTools Environment Configuration
# Copy this file to .env and update the values

# ===========================================
# Analytics Configuration
# ===========================================

# Google Analytics 4 Measurement ID
# Get this from your Google Analytics dashboard
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# SEO Configuration
# ===========================================

# Site URL (used for canonical URLs and Open Graph)
VITE_SITE_URL=https://www.securetools.dev

# Site Name (used in meta tags and structured data)
VITE_SITE_NAME=SecureTools

# Site Description (used in meta descriptions)
VITE_SITE_DESCRIPTION=Professional security and privacy tools that run entirely in your browser

# ===========================================
# Development Configuration
# ===========================================

# Development Mode (true/false)
# When true, enables additional logging and development features
VITE_DEV_MODE=false

# Debug Mode (true/false)
# When true, enables debug logging and error details
VITE_DEBUG_MODE=false

# ===========================================
# Security Configuration
# ===========================================

# Content Security Policy (CSP) Nonce
# Used for inline scripts and styles (if needed)
VITE_CSP_NONCE=

# Security Headers Configuration
# Enable/disable security headers in development
VITE_ENABLE_SECURITY_HEADERS=true

# ===========================================
# Performance Configuration
# ===========================================

# Enable Performance Monitoring (true/false)
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Enable Error Reporting (true/false)
VITE_ENABLE_ERROR_REPORTING=true

# Bundle Analysis (true/false)
# When true, includes bundle analysis in build
VITE_ENABLE_BUNDLE_ANALYSIS=true

# ===========================================
# Feature Flags
# ===========================================

# Enable PWA Features (true/false)
VITE_ENABLE_PWA=true

# Enable Service Worker (true/false)
VITE_ENABLE_SERVICE_WORKER=true

# Enable Offline Support (true/false)
VITE_ENABLE_OFFLINE=true

# Enable Dark Mode (true/false)
VITE_ENABLE_DARK_MODE=true

# ===========================================
# Example Usage
# ===========================================

# For development:
# VITE_GA_MEASUREMENT_ID=G-DEV1234567
# VITE_SITE_URL=http://localhost:8080
# VITE_DEV_MODE=true
# VITE_DEBUG_MODE=true

# For production:
# VITE_GA_MEASUREMENT_ID=G-PROD1234567
# VITE_SITE_URL=https://www.securetools.dev
# VITE_DEV_MODE=false
# VITE_DEBUG_MODE=false
